---
import BaseLayout from '../../layouts/BaseLayout.astro';

const email = 'jessie.jdfinance@gmail.com';
const phone = '027 423 3413';
const address = '7 St. Georges Bay Road, Parnell, Auckland 1052, New Zealand';
const adviserName = 'Changqing Dai（戴长青）';
---
<BaseLayout
  title="联系我们 — JD Finance"
  description="联系 JD Finance。联系 Changqing Dai 获取住房贷款、投资贷款和建筑贷款的专业金融建议。"
>
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="text-center mb-12">
      <h1 class="text-5xl mb-4">联系我们</h1>
      <p class="text-lg text-brand-700 max-w-2xl mx-auto">
        准备好讨论您的财务目标了吗？我很乐意听到您的声音。请通过电子邮件或电话联系我安排咨询。
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start">
      <!-- Contact Information -->
      <div>
        <div class="bg-brand-50 rounded-lg p-8 mb-8">
          <h2 class="text-2xl font-semibold mb-6 text-brand-900">联系方式</h2>

          <dl class="space-y-6">
            <div>
              <dt class="text-sm font-semibold text-brand-900 mb-1">金融顾问</dt>
              <dd class="text-brand-700 text-lg">{adviserName}</dd>
            </div>

            <div>
              <dt class="text-sm font-semibold text-brand-900 mb-1">电子邮件</dt>
              <dd>
                <a
                  href={`mailto:${email}`}
                  class="text-accent-600 hover:text-accent-500 transition-colors text-lg flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  {email}
                </a>
              </dd>
            </div>

            <div>
              <dt class="text-sm font-semibold text-brand-900 mb-1">电话</dt>
              <dd>
                <a
                  href={`tel:${phone.replace(/\s/g, '')}`}
                  class="text-accent-600 hover:text-accent-500 transition-colors text-lg flex items-center gap-2"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                  {phone}
                </a>
              </dd>
            </div>

            <div>
              <dt class="text-sm font-semibold text-brand-900 mb-1">办公地址</dt>
              <dd class="text-brand-700 flex items-start gap-2">
                <svg class="w-5 h-5 mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span>{address}</span>
              </dd>
            </div>
          </dl>

          <div class="mt-8 pt-8 border-t border-brand-100">
            <h3 class="text-sm font-semibold text-brand-900 mb-3">办公时间</h3>
            <p class="text-brand-700">周一至周五：上午9:00 - 下午5:00</p>
            <p class="text-brand-700 text-sm mt-2">可根据需要安排营业时间以外的预约</p>
          </div>
        </div>

        <!-- CTA Button -->
        <a
          href={`mailto:${email}`}
          class="w-full block text-center bg-brand-900 text-white px-8 py-4 hover:bg-accent-600 transition-colors rounded-lg font-semibold"
        >
          发送电子邮件
        </a>
      </div>

      <!-- Map -->
      <div>
        <div class="bg-white border border-brand-100 rounded-lg overflow-hidden shadow-sm">
          <div class="aspect-[4/3]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3192.5329877986434!2d174.77639231531856!3d-36.85134397993954!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6d0d47e7a2a1e2e9%3A0x506f8f8f8f8f8f8f!2s7%20St%20Georges%20Bay%20Rd%2C%20Parnell%2C%20Auckland%201052%2C%20New%20Zealand!5e0!3m2!1sen!2s!4v1234567890123!5m2!1sen!2s"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="JD Finance 办公室位置"
            ></iframe>
          </div>
          <div class="p-4 bg-brand-50">
            <p class="text-sm text-brand-700 text-center">
              <strong class="text-brand-900">办公室位置：</strong> 奥克兰 Parnell
            </p>
          </div>
        </div>

        <!-- Additional Info -->
        <div class="mt-6 bg-white border border-brand-100 rounded-lg p-6">
          <h3 class="font-semibold text-brand-900 mb-3">为什么联系我？</h3>
          <ul class="space-y-2 text-brand-700">
            <li class="flex gap-2">
              <span class="text-accent-600">✓</span>
              <span>住房、投资和建筑贷款的专业建议</span>
            </li>
            <li class="flex gap-2">
              <span class="text-accent-600">✓</span>
              <span>接触一系列值得信赖的贷款机构</span>
            </li>
            <li class="flex gap-2">
              <span class="text-accent-600">✓</span>
              <span>根据您的目标量身定制的个性化服务</span>
            </li>
            <li class="flex gap-2">
              <span class="text-accent-600">✓</span>
              <span>贷款维护的持续支持</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
